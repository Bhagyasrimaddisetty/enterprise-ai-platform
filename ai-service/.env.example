# JWT — must match auth-service's jwt.secret
JWT_SECRET=change-me-in-production-use-256-bit-secret
JWT_ALGORITHM=HS256

# LLM provider: "gemini" | "openai" | "none"
# Leave as "none" to run fully offline — resume scoring, RAG search, and
# template-based interview questions all work with no key at all.
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_API_KEY

OPENAI_API_KEY=YOUR_API_KEY


VECTOR_STORE_DIR=./data/vector_store
SKILLS_DICT_PATH=./data/skills/skills_dictionary.json
MAX_UPLOAD_MB=15
